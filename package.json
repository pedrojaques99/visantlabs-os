{
  "name": "vsn-mockup-machine",
  "version": "0.0.0",
  "description": "AI-powered canvas-based design tool with mockup generation, branding, and budget management",
  "type": "module",
  "keywords": [
    "canvas",
    "ai",
    "mockup",
    "design",
    "branding",
    "react",
    "typescript"
  ],
  "author": "Visant Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pedrojaques99/visantlabs-os"
  },
  "scripts": {
    "type-check": "tsc",
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "mcp:figma": "node --loader ts-node/esm server/mcp/figma-mcp.ts",
    "mcp:visant": "tsx mcp-server/index.ts",
    "dev:all": "node scripts/find-free-port.js",
    "stop:servers": "node scripts/stop-dev-server.js || true",
    "check:icons": "node scripts/check-icons.cjs",
    "build": "npm run stop:servers && npm run check:icons && npm run audit:visuals && npm run i18n:check && prisma generate && vite build",
    "audit:visuals": "node scripts/audit-visuals.mjs",
    "audit:fix-diamonds": "node scripts/audit-visuals.mjs --replace",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "postinstall": "prisma generate",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "i18n:audit": "node scripts/i18n-scanner.mjs",
    "i18n:check": "node scripts/i18n-scanner.mjs --strict",
    "i18n:consolidate": "node scripts/i18n-consolidate.mjs",
    "i18n:seed": "node scripts/i18n-seed-missing.mjs",
    "check-env": "node scripts/check-env.js",
    "check-r2": "node scripts/check-r2-env.js",
    "test-r2": "node scripts/test-r2-connection.js",
    "check-mongodb": "node scripts/check-mongodb-uri.js",
    "check-oauth": "node scripts/check-oauth.js",
    "check-stripe": "node scripts/check-stripe.js",
    "check-abacatepay": "node scripts/check-abacatepay.js",
    "check-mongo-env": "tsx server/scripts/check-mongo-env.ts",
    "encode-mongo-password": "node scripts/encode-mongodb-password.js",
    "generate-jwt-secret": "node scripts/generate-jwt-secret.js",
    "db:studio": "node scripts/run-prisma-studio.js",
    "migrate:credits": "tsx server/scripts/migrate-credits.ts",
    "sync:subscription": "tsx server/scripts/sync-subscription.ts",
    "process:credit-purchase": "tsx server/scripts/process-credit-purchase.ts",
    "list:users-stripe": "tsx server/scripts/list-users-stripe.ts",
    "update:subscription-manual": "tsx server/scripts/update-subscription-manual.ts",
    "fix:stripe-customer-id": "tsx server/scripts/fix-stripe-customer-id.ts",
    "create:resend-templates": "tsx server/scripts/create-resend-templates.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --project unit --project integration --project e2e --coverage",
    "test:validation": "vitest run server/utils/validation.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
