    "framer-motion": "^12.35.2",
    "google-auth-library": "^9.4.1",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^3.0.4",
    "jszip": "^3.10.1",
    "knip": "^5.82.1",
    "lru-cache": "^11.2.7",
    "lucide-react": "^0.418.0",
    "mongodb": "^6.21.0",
    "nanoid": "^5.1.7",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "perfect-freehand": "^1.2.2",
    "pino": "^9.5.0",
    "prisma": "^6.19.0",
    "qrcode.react": "^4.2.0",
    "rate-limit-redis": "^4.3.1",
    "react": "^19.2.0",
