#!/usr/bin/env bash
# Pre-commit hook: blocks commits containing secrets/API keys

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

STAGED=$(git diff --cached --name-only)

if [ -z "$STAGED" ]; then
  exit 0
fi

PATTERNS=(
  # Real key prefixes
  "sk_prod_[a-zA-Z0-9_-]{20,}"
  "sk_live_[a-zA-Z0-9_-]{20,}"
  "sk_test_[a-zA-Z0-9_-]{20,}"
  "pk_prod_[a-zA-Z0-9_-]{20,}"
  "pk_live_[a-zA-Z0-9_-]{20,}"
  "rk_live_[a-zA-Z0-9_-]{20,}"
  "whsec_[a-zA-Z0-9+/=]{20,}"
  # Anthropic / OpenAI
  "sk-ant-api[0-9]+-[a-zA-Z0-9_-]{80,}"
  "sk-proj-[a-zA-Z0-9_-]{40,}"
  # Stripe
  "sk_live_[a-zA-Z0-9]{24,}"
  # AWS
  "AKIA[0-9A-Z]{16}"
  # Generic high-entropy assignments (var = literal key)
  "(SECRET|API_KEY|PRIVATE_KEY|AUTH_TOKEN|ACCESS_TOKEN|WEBHOOK_SECRET)\s*=\s*['\"][a-zA-Z0-9+/._-]{32,}['\"]"
)

FOUND=0

for file in $STAGED; do
  # Skip binary files, lockfiles, and the hook itself
  case "$file" in
    *.png|*.jpg|*.jpeg|*.gif|*.ico|*.svg|*.woff*|*.ttf|*.eot) continue ;;
    package-lock.json|yarn.lock|pnpm-lock.yaml) continue ;;
    .githooks/*) continue ;;
  esac

  content=$(git diff --cached -- "$file" | grep "^+" | grep -v "^+++")

  for pattern in "${PATTERNS[@]}"; do
    matches=$(echo "$content" | grep -E "$pattern" || true)
    if [ -n "$matches" ]; then
      echo -e "${RED}[SECRET DETECTED]${NC} ${YELLOW}$file${NC}"
      echo "$matches" | head -3 | sed 's/^/  /'
      echo ""
      FOUND=1
    fi
  done
done

if [ $FOUND -eq 1 ]; then
  echo -e "${RED}Commit bloqueado: chaves/secrets detectados nos arquivos staged.${NC}"
  echo -e "Remova as chaves, use variáveis de ambiente (.env não commitado), e tente novamente."
  echo -e "Para bypass de emergência: ${YELLOW}git commit --no-verify${NC} (use com consciência)"
  exit 1
fi

exit 0
