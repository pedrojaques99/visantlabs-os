# Environment variables for Visant Labs
# Copy to .env and fill in your values

# ── AI Providers ──
GEMINI_API_KEY=
OPENAI_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
APIFREE_API_KEY=
BYTEPLUS_API_KEY=
IDEOGRAM_API_KEY=
REVE_API_KEY=

# ── Visant API ──
VISANT_API_TOKEN=

# ── Database ──
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/mockup-machine
MONGODB_DB_NAME=mockup-machine

# ── Server ──
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
JWT_SECRET=

# ── Google OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_PRODUCT_ID=
STRIPE_PRICE_ID_USD=
STRIPE_PRICE_ID_BRL=
STRIPE_PRODUCT_20=
STRIPE_PRODUCT_50=
STRIPE_PRODUCT_100=
STRIPE_PRODUCT_500=

# ── Better Auth ──
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000/

# ── Cloudflare R2 Storage ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Frontend (Vite) ──
VITE_FRONTEND_URL=http://localhost:3000
VITE_GEMINI_API_KEY=
VITE_LOGO_DEV_TOKEN=

# ── Liveblocks (Collaboration) ──
VITE_LIVEBLOCKS_PUBLIC_KEY=
LIVEBLOCKS_PUBLIC_KEY=
LIVEBLOCKS_SECRET_KEY=
LIVEBLOCKS_WEBHOOK_SECRET=

# ── AbacatePay (PIX) ──
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=
ABACATEPAY_WEBHOOK_ID=
ABACATE_PRODUCT_20=
ABACATE_PRODUCT_50=
ABACATE_PRODUCT_100=
ABACATE_PRODUCT_500=

# ── Resend (Email) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_WEBHOOK_KEY=

# ── Cron ──
CRON_SECRET=

# ── hCaptcha ──
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=
VITE_HCAPTCHA_SITE_KEY=

# ── API Key Encryption ──
API_KEY_ENCRYPTION_KEY=

# ── Rate Limiting ──
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_SIGNUP=3
RATE_LIMIT_MAX_SIGNIN=10

# ── Firecrawl / Serper ──
FIRECRAWL_API_KEY=
SERPER_API_KEY=

# ── Redis ──
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── Ollama (Local LLM) ──
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4
DEFAULT_LLM_PROVIDER=ollama

# ── Feature Flags ──
FEATURE_REFLECTION_LOOP=false
PATTERN_PROMOTION_THRESHOLD=5
AUTO_PROMOTE_PATTERNS=true
