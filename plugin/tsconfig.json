{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "downlevelIteration": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["@figma/plugin-typings"],
    "typeRoots": [
      "./node_modules/@types",
      "../node_modules/@types",
      "./node_modules/@figma"
    ],
    "paths": {
      "@/*": ["../src/*"],
      "@shared/*": ["../shared/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../src/lib/figma-types.ts",
    "../src/lib/utils.ts",
    "../src/lib/brandGuidelineSchema.ts",
    "../src/components/ui/**/*.ts",
    "../src/components/ui/**/*.tsx",
    "../src/components/shared/**/*.ts",
    "../src/components/shared/**/*.tsx",
    "../src/utils/clipboard.ts",
    "../src/utils/time.ts",
    "../src/utils/markdownRenderer.tsx",
    "../src/hooks/chat/useAutoScrollToBottom.ts",
    "../src/constants/geminiModels.ts",
    "../src/constants/openaiModels.ts",
    "../src/constants/seedreamModels.ts",
    "../src/types/types.ts",
    "../shared/types/chat.ts",
    "../node_modules/vite/client.d.ts"
  ]
}
