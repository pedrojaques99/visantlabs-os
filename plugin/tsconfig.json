{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "downlevelIteration": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "typeRoots": [
      "./node_modules/@types",
      "../node_modules/@types",
      "./node_modules/@figma"
    ],
    "paths": {
      "@/*": ["../src/*"],
      "@shared/*": ["../shared/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../src/lib/figma-types.ts",
    "../src/lib/utils.ts",
    "../src/components/**/*.ts",
    "../src/components/**/*.tsx"
  ]
}
