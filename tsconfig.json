{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "types": ["node"],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@server/*": ["./server/*"],
      "@shared/*": ["./shared/*"],
      "@visantlabs/psd-engine": ["./packages/psd-engine/src/index.ts"],
      "@visantlabs/psd-engine/scene": ["./packages/psd-engine/src/scene/index.ts"],
      "@visantlabs/psd-engine/adapters/node": ["./packages/psd-engine/src/adapters/node.ts"],
      "@visantlabs/psd-engine/adapters/browser": ["./packages/psd-engine/src/adapters/browser.ts"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "exclude": ["node_modules", "dist", "build", "tmp", "**/*.example.ts", "plugin", "cli"]
}
