# =============================================================================
# VPS / Coolify Environment Variables
# Copy this file, fill in your values, and set them in Coolify's environment
# variables panel. Do NOT commit actual values.
# See deploy/coolify.md for full setup instructions.
# =============================================================================

# Visant internal API token
VISANT_API_TOKEN=

# AI providers
GEMINI_API_KEY=
OPENAI_KEY=
APIFREE_API_KEY=
FIRECRAWL_API_KEY=
SERPER_API_KEY=

# MongoDB
MONGODB_URI=
MONGODB_DB_NAME=

# PostgreSQL / Prisma
DATABASE_URL=

# Server
PORT=3001
NODE_ENV=production

# CORS — comma-separated list of allowed frontend origins
FRONTEND_URL=https://visantlabs.com,https://www.visantlabs.com

# JWT
JWT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.visantlabs.com/api/auth/google/callback

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_PRODUCT_ID=
STRIPE_PRICE_ID_USD=
STRIPE_PRICE_ID_BRL=
STRIPE_PRODUCT_20=
STRIPE_PRODUCT_50=
STRIPE_PRODUCT_100=
STRIPE_PRODUCT_500=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://api.visantlabs.com/

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Liveblocks
LIVEBLOCKS_PUBLIC_KEY=
LIVEBLOCKS_SECRET_KEY=
LIVEBLOCKS_WEBHOOK_SECRET_KEY=

# AbacatePay
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=
ABACATEPAY_WEBHOOK_ID=
ABACATE_PRODUCT_20=
ABACATE_PRODUCT_50=
ABACATE_PRODUCT_100=
ABACATE_PRODUCT_500=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_KEY=

# hCaptcha
HCAPTCHA_SECRET_KEY=

# API Key encryption
API_KEY_ENCRYPTION_KEY=

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_SIGNUP=3
RATE_LIMIT_MAX_SIGNIN=10

# WhatsApp community link
WHATSAPP_GROUP_URL=

# Pinecone
PINECONE_KEY=

# Redis
REDIS_URL=redis://localhost:6379
REDIS_USERNAME=default
REDIS_PASSWORD=

# Ollama (optional, for local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4
DEFAULT_LLM_PROVIDER=ollama

# Feature flags
FEATURE_REFLECTION_LOOP=false
PATTERN_PROMOTION_THRESHOLD=5
AUTO_PROMOTE_PATTERNS=true
