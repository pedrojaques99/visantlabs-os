{
  "name": "@visant/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Visant Labs API — auto-generated from OpenAPI spec",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "generate": "openapi --input ./openapi.json --output ./src --client fetch",
    "build": "tsc",
    "prebuild": "npm run generate"
  },
  "keywords": ["visant", "sdk", "brand", "ai", "openapi"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/visantlabs/visantlabs-os"
  },
  "devDependencies": {
    "openapi-typescript-codegen": "^0.29.0",
    "typescript": "^5.4.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
