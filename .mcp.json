{
  "mcpServers": {
    "visant-remote": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://api.visantlabs.com/api/mcp",
        "--header",
        "Authorization:Bearer ${VISANT_API_TOKEN}"
      ],
      "env": {
        "VISANT_API_TOKEN": "${VISANT_API_TOKEN}"
      }
    }
  }
}